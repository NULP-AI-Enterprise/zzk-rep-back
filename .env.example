# ── Database ──────────────────────────────────────────────────────────────────
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB below
DATABASE_URL=postgresql+asyncpg://zzk:secret@postgres:5432/zzk_db
DB_SSL=false          # set true when connecting to Supabase / RDS / any cloud Postgres

# Postgres container credentials (used by the postgres service, not the app)
POSTGRES_USER=zzk
POSTGRES_PASSWORD=secret
POSTGRES_DB=zzk_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
SURNAME_ENCRYPTION_KEY=change-me-to-a-32-byte-fernet-key

# ── Email (Celery reminders) ──────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=smtp-password

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
HOST_PORT=8000        # host port the API is exposed on
